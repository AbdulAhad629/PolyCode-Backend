{
  "info": {
    "name": "PolyCode — Polycoder Progress",
    "description": "Polycoder progress API.\n\nCorrect route (from auth.router.js):\nGET /api/auth/polycoder/:username/progress\n\nUse environment PolyCode — Production or PolyCode — Local.\nDo not put spaces in the URL. Method is GET in the dropdown only.\n\nProduction backend must be deployed first — if you get 404 on a clean URL, push backend code to Vercel.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "apiProtocol",
      "value": "http"
    },
    {
      "key": "apiHost",
      "value": "localhost:5000"
    },
    {
      "key": "polycoderUsername",
      "value": "amina"
    },
    {
      "key": "authToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Login (get token)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"you@example.com\",\n  \"password\": \"your_password\"\n}"
        },
        "url": {
          "raw": "{{apiProtocol}}://{{apiHost}}/api/auth/login",
          "protocol": "{{apiProtocol}}",
          "host": ["{{apiHost}}"],
          "path": ["api", "auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "if (json.token) {",
              "  pm.collectionVariables.set('authToken', json.token);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get polycoder progress by username",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{apiProtocol}}://{{apiHost}}/api/auth/polycoder/{{polycoderUsername}}/progress",
          "protocol": "{{apiProtocol}}",
          "host": ["{{apiHost}}"],
          "path": ["api", "auth", "polycoder", "{{polycoderUsername}}", "progress"]
        },
        "description": "Returns full polycoder progress including `pointsByDay` — an array of each day with points earned (lesson XP + read bonus), courses, and per-lesson breakdown."
      }
    },
    {
      "name": "Get my polycoder progress (auth)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "url": {
          "raw": "{{apiProtocol}}://{{apiHost}}/api/auth/polycoder/me/progress",
          "protocol": "{{apiProtocol}}",
          "host": ["{{apiHost}}"],
          "path": ["api", "auth", "polycoder", "me", "progress"]
        }
      }
    },
    {
      "name": "Get polycoder daily points by username",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{apiProtocol}}://{{apiHost}}/api/auth/polycoder/{{polycoderUsername}}/daily-points",
          "protocol": "{{apiProtocol}}",
          "host": ["{{apiHost}}"],
          "path": ["api", "auth", "polycoder", "{{polycoderUsername}}", "daily-points"]
        },
        "description": "Returns only daily points: `pointsByDay` array with date, pointsEarned, lessonPoints, readBonusPoints, courses, and per-lesson breakdown."
      }
    },
    {
      "name": "Get my polycoder daily points (auth)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "url": {
          "raw": "{{apiProtocol}}://{{apiHost}}/api/auth/polycoder/me/daily-points",
          "protocol": "{{apiProtocol}}",
          "host": ["{{apiHost}}"],
          "path": ["api", "auth", "polycoder", "me", "daily-points"]
        }
      }
    }
  ]
}
